-- ==================== TRANG BỔ TRỢ DELTA ====================
SectionBoTro:addButton("⚡ Tối Ưu Đồ Họa (Giảm Lag)", function()
    pcall(function()
        game:GetService("Lighting").FogEnd = 999999
        for _, v in pairs(game:GetService("Lighting"):GetChildren()) do
            if v:IsA("Atmosphere") or v:IsA("Sky") then v:Destroy() end
        end
    end)
end)

SectionBoTro:addButton("🔥 SIÊU FIX LAG (Xóa Texture & Hiệu Ứng)", function()
    pcall(function()
        game:GetService("Lighting").GlobalShadows = false
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("Decal") or v:IsA("Texture") then
                v:Destroy()
            elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Sparkles") then
                v.Enabled = false
            elseif v:IsA("MeshPart") then
                v.TextureID = ""
                v.CollisionFidelity = Enum.CollisionFidelity.Box
            elseif v:IsA("Part") or v:IsA("CornerWedgePart") or v:IsA("TrussPart") or v:IsA("WedgePart") then
                v.Material = Enum.Material.SmoothPlastic
                v.Reflectance = 0
            end
        end
    end)
end)

-- ==================== THUẬT TOÁN ĐỊNH VỊ CĂN GIỮA MÀN HÌNH ====================
local MainGui = nil
local MainMenuFrame = nil

for _, v in pairs(game.CoreGui:GetChildren()) do
    if v:IsA("ScreenGui") and v:FindFirstChild("Main") then
        v.Name = "ThangLoVenyx"
        MainGui = v
        MainMenuFrame = v.Main
        break
    end
end

if MainMenuFrame then
    MainMenuFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    MainMenuFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
end

-- ==================== CƠ CHẾ NÚT TRÒN BẬT/TẮT CAO CẤP (CHỐNG LỆCH) ====================
local ToggleGui = Instance.new("ScreenGui")
local ToggleButton = Instance.new("TextButton")
local UICorner = Instance.new("UICorner")
local UIGradient = Instance.new("UIGradient")

ToggleGui.Name = "ThangLoToggleGui"
ToggleGui.Parent = game.CoreGui
ToggleGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

ToggleButton.Parent = ToggleGui
ToggleButton.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
ToggleButton.Position = UDim2.new(0, 20, 0, 150)
ToggleButton.Size = UDim2.new(0, 60, 0, 60)
ToggleButton.Font = Enum.Font.GothamBold
ToggleButton.Text = "Thắng Lỏ"
ToggleButton.TextColor3 = Color3.fromRGB(0, 255, 255)
ToggleButton.TextSize = 12.00
ToggleButton.Draggable = true 

UICorner.CornerRadius = UDim.new(0, 50)
UICorner.Parent = ToggleButton

UIGradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 240, 255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 80, 255))
}
UIGradient.Parent = ToggleButton

local MenuDangMo = true

ToggleButton.MouseButton1Click:Connect(function()
    if MainGui and MainMenuFrame then
        if MenuDangMo then
            MainGui.Enabled = false
            MainMenuFrame.Position = UDim2.new(0, -9999, 0, -9999)
            MenuDangMo = false
            ToggleButton.TextColor3 = Color3.fromRGB(150, 150, 150)
        else
            MainMenuFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
            MainGui.Enabled = true
            MenuDangMo = true
            ToggleButton.TextColor3 = Color3.fromRGB(0, 255, 255)
        end
    end
end)
