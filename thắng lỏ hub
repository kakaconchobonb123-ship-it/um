-- 8. KIỂM TRA FILE KEY ĐÃ LƯU KHI CHẠY SCRIPT
local Key_Is_Valid = false

if readfile and isfile and isfile(Storage_File_Name) then
    local success, content = pcall(function() return readfile(Storage_File_Name) end)
    if success and content then
        local data = string.split(content, "|")
        local savedKey = data[1]
        local savedDate = data[2]
        
        if savedKey == System_Correct_Key and savedDate == Current_Day_String then
            Key_Is_Valid = true
        else
            pcall(function() delfile(Storage_File_Name) end)
        end
    end
end

-- PHÂN LUỒNG KHỞI CHẠY CHÍNH THỨC
if Key_Is_Valid then
    OpenMainMenu()
else
    CreateKeySystemGui()
end
