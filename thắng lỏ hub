local dateTable = os.date("*t")
local Current_Day_String = tostring(dateTable.day) .. "/" .. tostring(dateTable.month) .. "/" .. tostring(dateTable.year)

local function GenerateDailyRandomKey()
    local seed = (dateTable.day * 31) + (dateTable.month * 7) + (dateTable.year - 2000)
    math.randomseed(seed)
    
    local chars = "ABCDEFGHJKLMNPQRSTUVWXYZ123456789"
    local randomLength = 6
    local randomCode = ""
    
    for i = 1, randomLength do
        local randIndex = math.random(1, #chars)
        randomCode = randomCode .. string.sub(chars, randIndex, randIndex)
    end
    
    return "TL-HUB-" .. randomCode
end

local System_Correct_Key = GenerateDailyRandomKey()

