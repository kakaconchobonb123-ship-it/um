        if setclipboard then setclipboard(text)
        elseif toclipboard then toclipboard(text)
        end
    end)
    return s
end

-- --- HÀM TẠO TÍNH NĂNG KÉO THẢ (DRAGGABLE) ---
local UserInputService = game:GetService("UserInputService")
local isMaximized = false 

local function MakeWindowDraggable(frame, dragHandle)
    local dragging, dragInput, dragStart, startPos
    dragHandle = dragHandle or frame

    dragHandle.InputBegan:Connect(function(input)
        if isMaximized then return end 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragHandle.InputChanged:Connect(function(input)
        if isMaximized then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging and not isMaximized then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X, 
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- --- HÀM RAINBOW ---
local function ApplyRainbowAura(uiStroke)
    task.spawn(function()
        local tickCount = 0
        while uiStroke and uiStroke.Parent do
            if not uiStroke or not uiStroke.Parent then break end
            uiStroke.Color = Color3.fromHSV(tickCount, 0.8, 1)
            tickCount = tickCount + 0.005
            if tickCount >= 1 then tickCount = 0 end
            task.wait(0.03)
        end
    end)
end

