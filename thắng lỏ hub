local function CreateScriptButton(parent, text, scriptUrl)
    local Btn = Instance.new("TextButton", parent)
    Btn.Size = UDim2.new(0.96, 0, 0, 44)
    Btn.BackgroundColor3 = Color3.fromRGB(22, 22, 32)
    Btn.BackgroundTransparency = 0.15 
    Btn.Font = Enum.Font.Ubuntu 
    Btn.Text = text
    Btn.TextColor3 = Color3.fromRGB(230, 230, 240)
    Btn.TextSize = 14
    Btn.ZIndex = 4
    Btn.TextXAlignment = Enum.TextXAlignment.Center
    Btn.TextYAlignment = Enum.TextYAlignment.Center
    Btn.TextWrapped = true 
    
    local Padding = Instance.new("UIPadding", Btn)
    Padding.PaddingLeft = UDim.new(0, 15)
    Padding.PaddingRight = UDim.new(0, 15)

    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)
    local Stroke = Instance.new("UIStroke", Btn)
    Stroke.Color = Color3.fromRGB(40, 40, 60)
    table.insert(TextElements.Buttons, Btn)
    
    local runningStatus = "idle" 
    
    Btn.MouseButton1Click:Connect(function()
        if runningStatus == "idle" or runningStatus == "failed" then
            runningStatus = "loading"
            Btn.Text = "[ĐANG TẢI...] " .. text
            Btn.TextColor3 = Color3.fromRGB(255, 200, 0)
            Stroke.Color = Color3.fromRGB(200, 150, 0)
            
            local loadedSuccess = false
            task.spawn(function()
                local success, err = pcall(function() 
                    loadstring(game:HttpGet(scriptUrl))() 
                end)
                if success then
                    loadedSuccess = true
                    runningStatus = "success"
                    Btn.Text = "[ĐANG CHẠY] " .. text
                    Btn.TextColor3 = Color3.fromRGB(0, 255, 150)
                    Stroke.Color = Color3.fromRGB(0, 150, 100)
                end
            end)
            
            task.spawn(function()
                task.wait(8)
                if not loadedSuccess and runningStatus == "loading" then
                    runningStatus = "failed"
                    Btn.Text = "[LỖI KHỞI ĐỘNG] " .. text
                    Btn.TextColor3 = Color3.fromRGB(255, 75, 75)
                    Stroke.Color = Color3.fromRGB(180, 30, 30)
                end
            end)
        elseif runningStatus == "success" then
            runningStatus = "idle"
            Btn.Text = "Tải Lại: " .. text
            Btn.TextColor3 = Color3.fromRGB(0, 230, 255)
            Stroke.Color = Color3.fromRGB(40, 40, 60)
        end
    end)
end

